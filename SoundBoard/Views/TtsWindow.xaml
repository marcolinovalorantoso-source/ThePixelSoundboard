<Window x:Class="SoundBoard.Views.TtsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:SoundBoard.Services"
        Title="{Binding TtsTitle, Source={x:Static services:L10n.Instance}}" Width="480" Height="360"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1B1D23" Icon="/settings_icon.ico">
    <Window.Resources>
        <!-- Custom colors -->
        <SolidColorBrush x:Key="BgPanelBrush" Color="#232631"/>
        <SolidColorBrush x:Key="BgElevatedBrush" Color="#2A2E3A"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F1F2F6"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9AA0AE"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#5B8C5A"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#2ECC71"/>

        <!-- ComboBox styling -->
        <Style x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="#2A2E3A" BorderBrush="#3A3F4E" BorderThickness="1" CornerRadius="6">
                            <Grid HorizontalAlignment="Right" Width="30">
                                <Path x:Name="Arrow" Fill="#F1F2F6" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#353A49"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4C5265"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A2E3A"/>
                                <Setter TargetName="Arrow" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="180" CenterX="4" CenterY="2"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="ComboBoxTemplate" TargetType="ComboBox">
            <Grid>
                <ToggleButton Style="{StaticResource ComboBoxToggleButton}" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press"/>
                <ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" Margin="10,6,30,6" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                    <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                        <Border Name="DropDownBorder" Background="#232631" BorderBrush="#3A3F4E" BorderThickness="1" CornerRadius="6" Margin="0,2,0,0">
                            <ScrollViewer Margin="4" SnapsToDevicePixels="True" HorizontalScrollBarVisibility="Auto">
                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Popup>
            </Grid>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="Template" Value="{StaticResource ComboBoxTemplate}"/>
            <Setter Property="Foreground" Value="#F1F2F6"/>
            <Setter Property="Background" Value="#2A2E3A"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#F1F2F6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Name="Border" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True" CornerRadius="4">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#5B8C5A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#5B8C5A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title/Description -->
            <RowDefinition Height="*"/>    <!-- Text input -->
            <RowDefinition Height="Auto"/> <!-- Settings (Voice, Speed) -->
            <RowDefinition Height="Auto"/> <!-- Actions -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="{Binding TtsHeader, Source={x:Static services:L10n.Instance}}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="{Binding TtsDesc, Source={x:Static services:L10n.Instance}}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Text Input -->
        <TextBox x:Name="TtsTextBox" Grid.Row="1" Margin="0,0,0,16" Padding="10" FontSize="14"
                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 Background="{StaticResource BgPanelBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                 BorderBrush="#3A3F4E" BorderThickness="1"
                 MaxLength="300"
                 GotFocus="TtsTextBox_GotFocus" LostFocus="TtsTextBox_LostFocus"/>

        <!-- Settings -->
        <Border Grid.Row="2" Background="{StaticResource BgPanelBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Voice Selection -->
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="{Binding SelectVoice, Source={x:Static services:L10n.Instance}}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="VoiceComboBox" DisplayMemberPath="DisplayName" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="{Binding Speed, Source={x:Static services:L10n.Instance}}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="RateValueText" Text="{Binding NormalSpeed, Source={x:Static services:L10n.Instance}}" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                    <Slider x:Name="RateSlider" Minimum="-10" Maximum="10" Value="0" SmallChange="1" LargeChange="2" Margin="0,6,0,0" ValueChanged="RateSlider_ValueChanged"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Actions -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Test/Preview locally (only for Me) -->
            <Button Grid.Column="0" Content="{Binding PlayBtn, Source={x:Static services:L10n.Instance}}" Padding="16,10" Width="130" FontWeight="Bold" Click="Speak_Click"/>
            
            <!-- Save to grid -->
            <Button Grid.Column="2" Content="{Binding SaveAsButton, Source={x:Static services:L10n.Instance}}" Style="{StaticResource FlatButton}" Padding="16,10" Width="160" Click="SaveButton_Click" Background="{StaticResource AccentBrush}"/>
        </Grid>
    </Grid>
</Window>
