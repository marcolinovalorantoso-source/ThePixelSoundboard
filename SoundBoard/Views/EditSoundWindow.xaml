<Window x:Class="SoundBoard.Views.EditSoundWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modifica suono" Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1B1D23" Foreground="#F1F2F6">
    <StackPanel Margin="20">
        <TextBlock Text="Nome" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
        <TextBox x:Name="NameTextBox" Margin="0,0,0,16"/>

        <TextBlock Text="Icona" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="IconTextBox" Grid.Column="0" Margin="0,0,8,0"/>
            <ItemsControl Grid.Column="1" ItemsSource="{Binding IconPresets, RelativeSource={RelativeSource AncestorType=Window}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding}" Width="28" Height="28" Margin="2" FontSize="14"
                                Click="IconPreset_Click"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <TextBlock Text="Colore" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
        <ItemsControl ItemsSource="{Binding ColorPresets, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,0,16">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Width="28" Height="28" Margin="2" CornerRadius="6" Background="{Binding}"
                            MouseLeftButtonUp="ColorPreset_Click" Cursor="Hand"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Annulla" Width="90" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Salva" Width="90" Background="{StaticResource AccentBrush}" Click="Save_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
