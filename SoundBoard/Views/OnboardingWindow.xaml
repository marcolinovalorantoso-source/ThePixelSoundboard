<Window x:Class="SoundBoard.Views.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Benvenuto in ThePixelSoundboard" 
        Width="750" Height="500"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        Icon="/settings_icon.ico">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Animazione slide e dissolvenza -->
            <Storyboard x:Key="SlideInFromRight">
                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.35">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="50" To="0" Duration="0:0:0.35">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <!-- Card Style per i Quick Tips -->
            <Style x:Key="TipCardStyle" TargetType="Border">
                <Setter Property="Background" Value="#232631"/>
                <Setter Property="BorderBrush" Value="#2A2E3A"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Padding" Value="16"/>
                <Setter Property="Margin" Value="6"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="16" Background="#1B1D23" BorderBrush="#3A3F4E" BorderThickness="1.5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="45"/>
                <!-- Custom Title Bar -->
                <RowDefinition Height="*"/>
                <!-- Content Area -->
                <RowDefinition Height="60"/>
                <!-- Bottom Action Bar -->
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Grid.Row="0" Background="#14161D" CornerRadius="16,16,0,0" MouseDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🎵" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="ThePixelSoundboard — Setup Iniziale" FontWeight="Bold" Foreground="#3498DB" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center" 
                            Background="Transparent" BorderThickness="0" Foreground="#F1F2F6" FontSize="16" FontWeight="Bold"
                            Padding="8,4" Click="SkipButton_Click" Cursor="Hand" ToolTip="Chiudi e Salta"/>
                </Grid>
            </Border>

            <!-- Content Area with Wizard Steps -->
            <Grid Grid.Row="1" Margin="24,16">
                <!-- STEP 1: WELCOME SCREEN -->
                <Grid x:Name="StepWelcome" Visibility="Visible" RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <TranslateTransform X="0" Y="0"/>
                    </Grid.RenderTransform>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left side art/banner -->
                    <Border Grid.Column="0" CornerRadius="10" Background="#232631" BorderBrush="#2A2E3A" BorderThickness="1" Margin="0,0,16,0">
                        <Grid>
                            <Grid.Background>
                                <RadialGradientBrush Center="0.5,0.5" RadiusX="0.6" RadiusY="0.6">
                                    <GradientStop Color="#1A3498DB" Offset="0"/>
                                    <GradientStop Color="#00000000" Offset="1"/>
                                </RadialGradientBrush>
                            </Grid.Background>
                            
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Border Width="110" Height="110" CornerRadius="55" Background="#1B1D23" BorderBrush="#3498DB" BorderThickness="2" Margin="0,0,0,20">
                                    <TextBlock Text="🎧" FontSize="56" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="ThePixelBoys" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#3498DB" FontSize="16"/>
                                <TextBlock Text="Soundboard v2.5.0" HorizontalAlignment="Center" Foreground="#9AA0AE" FontSize="11" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Right side welcome text -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="Benvenuto a bordo!" FontSize="28" FontWeight="Bold" Foreground="#F1F2F6" Margin="0,0,0,12"/>
                        
                        <TextBlock Text="Grazie per aver scelto ThePixelSoundboard! Abbiamo progettato questa applicazione per rendere la riproduzione di effetti sonori e sintesi vocali in chiamata estremamente semplice e fluida." 
                                   TextWrapping="Wrap" Foreground="#F1F2F6" FontSize="13" LineHeight="20" Margin="0,0,0,16"/>

                        <TextBlock Text="Per iniziare a riprodurre audio nei tuoi canali Discord o di gioco senza problemi, ti guideremo ora nella configurazione veloce dei tuoi canali audio." 
                                   TextWrapping="Wrap" Foreground="#9AA0AE" FontSize="12" LineHeight="18" Margin="0,0,0,24"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Inizia Configurazione  🚀" Style="{StaticResource FlatButton}" Background="#3498DB" Foreground="White" 
                                    Padding="20,12" FontSize="14" FontWeight="Bold" Margin="0,0,12,0" Click="NextButton_Click"/>
                            <Button Content="Salta Configurazione  ✕" Style="{StaticResource FlatButton}" Background="#2A2E3A" Foreground="#F1F2F6" 
                                    Padding="16,12" FontSize="13" FontWeight="SemiBold" Click="ExpertButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- STEP 2: AUDIO CONFIGURATION -->
                <Grid x:Name="StepAudio" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <TranslateTransform X="0" Y="0"/>
                    </Grid.RenderTransform>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Configura il tuo Canale Audio" FontSize="20" FontWeight="Bold" Foreground="#F1F2F6" Margin="0,0,0,4"/>
                        <TextBlock Text="Seleziona i tuoi dispositivi audio. Per trasmettere ai tuoi amici, ti consigliamo di usare un cavo virtuale (es. VB-Cable) impostato come output amici, e di usarlo come microfono su Discord."
                                   TextWrapping="Wrap" Foreground="#9AA0AE" FontSize="11.5" LineHeight="16"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Column: Output Selection -->
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <!-- Device for Me -->
                            <TextBlock Text="1. Ascolto Personale (Tu)" FontWeight="Bold" Foreground="#3498DB" FontSize="12" Margin="0,0,0,4"/>
                            <TextBlock Text="Il dispositivo principale da cui ascolti l'audio (le tue cuffie)." Foreground="#9AA0AE" FontSize="10.5" Margin="0,0,0,6"/>
                            <ComboBox x:Name="ComboMe" Height="34" Margin="0,0,0,16" DisplayMemberPath="Name" SelectedValuePath="Id"/>

                            <!-- Device for Friends -->
                            <TextBlock Text="2. Output per Amici (Discord)" FontWeight="Bold" Foreground="#2ECC71" FontSize="12" Margin="0,0,0,4"/>
                            <TextBlock Text="Scegli il cavo virtuale (es. CABLE Input) per trasmettere i suoni ai tuoi amici." Foreground="#9AA0AE" FontSize="10.5" Margin="0,0,0,6"/>
                            <ComboBox x:Name="ComboFriends" Height="34" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                        </StackPanel>

                        <!-- Right Column: Mic Loopback -->
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="3. Il Tuo Microfono Reale" FontWeight="Bold" Foreground="#F1C40F" FontSize="12" Margin="0,0,0,4"/>
                            <TextBlock Text="L'app mixerà la tua voce con i suoni del soundboard sul cavo virtuale, così i tuoi amici sentiranno entrambi." Foreground="#9AA0AE" TextWrapping="Wrap" FontSize="10.5" Margin="0,0,0,6"/>
                            <ComboBox x:Name="ComboMic" Height="34" Margin="0,0,0,16" DisplayMemberPath="Name" SelectedValuePath="Id"/>

                            <!-- Help Box -->
                            <Border Background="#232631" CornerRadius="8" Padding="12,10" BorderBrush="#2A2E3A" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="💡 Configurazione Discord:" FontWeight="Bold" Foreground="#F1F2F6" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBlock Text="Su Discord, vai in Impostazioni &gt; Voce e Video, ed imposta come dispositivo di ingresso lo stesso cavo virtuale selezionato qui a sinistra (es. CABLE Output)."
                                               TextWrapping="Wrap" Foreground="#9AA0AE" FontSize="10" LineHeight="14"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- STEP 3: QUICK TIPS -->
                <Grid x:Name="StepTips" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <TranslateTransform X="0" Y="0"/>
                    </Grid.RenderTransform>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Come Usare ThePixelSoundboard" FontSize="20" FontWeight="Bold" Foreground="#F1F2F6" Margin="0,0,0,4"/>
                        <TextBlock Text="Scopri i comandi rapidi per sfruttare al meglio la tua nuova applicazione." Foreground="#9AA0AE" FontSize="12"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Tip 1 -->
                        <Border Grid.Column="0" Style="{StaticResource TipCardStyle}">
                            <StackPanel>
                                <TextBlock Text="📁" FontSize="28" Margin="0,0,0,12" HorizontalAlignment="Center"/>
                                <TextBlock Text="Importa i Suoni" FontWeight="Bold" Foreground="#F1F2F6" FontSize="13" Margin="0,0,0,6" HorizontalAlignment="Center"/>
                                <TextBlock Text="Trascina e rilascia qualsiasi file audio (.wav, .mp3, .ogg) direttamente nella finestra dell'app per importarlo all'istante." 
                                           TextWrapping="Wrap" Foreground="#9AA0AE" FontSize="11" LineHeight="16" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Tip 2 -->
                        <Border Grid.Column="1" Style="{StaticResource TipCardStyle}">
                            <StackPanel>
                                <TextBlock Text="⌨️" FontSize="28" Margin="0,0,0,12" HorizontalAlignment="Center"/>
                                <TextBlock Text="Tasti di Scelta Rapida" FontWeight="Bold" Foreground="#F1F2F6" FontSize="13" Margin="0,0,0,6" HorizontalAlignment="Center"/>
                                <TextBlock Text="Fai clic destro su un pulsante audio, seleziona 'Modifica' e assegna una combinazione di tasti per riprodurlo al volo anche in gioco." 
                                           TextWrapping="Wrap" Foreground="#9AA0AE" FontSize="11" LineHeight="16" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Tip 3 -->
                        <Border Grid.Column="2" Style="{StaticResource TipCardStyle}">
                            <StackPanel>
                                <TextBlock Text="🛠️" FontSize="28" Margin="0,0,0,12" HorizontalAlignment="Center"/>
                                <TextBlock Text="Menu Strumenti" FontWeight="Bold" Foreground="#F1F2F6" FontSize="13" Margin="0,0,0,6" HorizontalAlignment="Center"/>
                                <TextBlock Text="Apri la barra laterale per cercare online su MyInstants, registrare audio al volo dal microfono o creare sintesi vocali TTS personalizzate." 
                                           TextWrapping="Wrap" Foreground="#9AA0AE" FontSize="11" LineHeight="16" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Bottom Action Bar -->
            <Border x:Name="BottomBar" Grid.Row="2" Background="#14161D" CornerRadius="0,0,16,16" Padding="20,0">
                <Grid>
                    <!-- Step Progress Indicators (Dots) -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Ellipse x:Name="Dot1" Width="8" Height="8" Fill="#3498DB" Margin="0,0,6,0"/>
                        <Ellipse x:Name="Dot2" Width="8" Height="8" Fill="#3A3F4E" Margin="0,0,6,0"/>
                        <Ellipse x:Name="Dot3" Width="8" Height="8" Fill="#3A3F4E"/>
                    </StackPanel>

                    <!-- Back / Next buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="BackButton" Content="Indietro" Width="90" Height="34" Margin="0,0,10,0" 
                                Style="{StaticResource FlatButton}" Visibility="Collapsed" Click="BackButton_Click"/>
                        <Button x:Name="NextButton" Content="Avanti" Width="100" Height="34" Background="#3498DB" 
                                Foreground="White" Style="{StaticResource FlatButton}" Click="NextButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
