<Window x:Class="SoundBoard.Views.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rinomina" Width="340" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1B1D23" Foreground="#F1F2F6">
    <StackPanel Margin="20">
        <TextBlock Text="Nuovo nome:" Margin="0,0,0,8"/>
        <TextBox x:Name="NameTextBox" Margin="0,0,0,16" KeyDown="NameTextBox_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Annulla" Width="90" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Salva" Width="90" Background="{StaticResource AccentBrush}" Click="Save_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
