<Window x:Class="SoundBoard.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Impostazioni" Width="750" MinWidth="600" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Background="#1B1D23" Icon="/settings_icon.ico">
    <Window.Resources>
        <Style x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="#2A2E3A" BorderBrush="#3A3F4E" BorderThickness="1" CornerRadius="6">
                            <Grid HorizontalAlignment="Right" Width="30">
                                <Path x:Name="Arrow" Fill="#F1F2F6" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#353A49"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4C5265"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A2E3A"/>
                                <Setter TargetName="Arrow" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="180" CenterX="4" CenterY="2"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="ComboBoxTemplate" TargetType="ComboBox">
            <Grid>
                <ToggleButton Style="{StaticResource ComboBoxToggleButton}" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press"/>
                <ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" Margin="10,6,30,6" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                    <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                        <Border Name="DropDownBorder" Background="#232631" BorderBrush="#3A3F4E" BorderThickness="1" CornerRadius="6" Margin="0,2,0,0">
                            <ScrollViewer Margin="4" SnapsToDevicePixels="True" HorizontalScrollBarVisibility="Auto">
                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Popup>
            </Grid>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="Template" Value="{StaticResource ComboBoxTemplate}"/>
            <Setter Property="Foreground" Value="#F1F2F6"/>
            <Setter Property="Background" Value="#2A2E3A"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#F1F2F6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Name="Border" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True" CornerRadius="4">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#6C8CFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#6C8CFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="20">

        <!-- Stato Driver Virtuale -->
        <Border x:Name="DriverStatusBorder" CornerRadius="8" Padding="14,12" Margin="0,0,0,20">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="DriverStatusIcon" Text="🎙️" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock x:Name="DriverStatusTitle" FontSize="13" FontWeight="Bold" Foreground="#F1F2F6"/>
                        <TextBlock x:Name="DriverStatusSubtitle" FontSize="11" Foreground="#9AA0AE" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Toggle per abilitare/disabilitare manualmente la modalità Driver Virtuale -->
        <CheckBox x:Name="UseVirtualDriverCheckBox"
                  Content="Usa Driver Audio Virtuale (Microfono integrato)"
                  Margin="0,0,0,20"
                  Checked="UseVirtualDriverCheckBox_Changed"
                  Unchecked="UseVirtualDriverCheckBox_Changed"
                  Foreground="#F1F2F6"
                  FontWeight="Bold"/>

        <!-- Output Amici (nascosto se driver virtuale presente) -->
        <StackPanel x:Name="FriendsOutputPanel">
            <TextBlock Text="Dispositivo output (Amici / Discord)" Foreground="#F1F2F6" Margin="0,0,0,6" FontWeight="Bold"/>
            <ComboBox x:Name="OutputFriendsComboBox" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,20"
                      SelectionChanged="OutputFriendsComboBox_SelectionChanged"/>
        </StackPanel>

        <!-- Output Cuffie (sempre visibile) -->
        <TextBlock Text="🎧  Output (Tue cuffie / Speaker)" Foreground="#F1F2F6" Margin="0,0,0,6" FontWeight="Bold"/>
        <ComboBox x:Name="OutputMeComboBox" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,20"
                  SelectionChanged="OutputMeComboBox_SelectionChanged"/>

        <!-- Microfono Fisico (visibile solo se driver virtuale presente) -->
        <StackPanel x:Name="PhysicalMicPanel" Visibility="Collapsed">
            <TextBlock Text="🎤  Tuo microfono reale (Input)" Foreground="#F1F2F6" Margin="0,0,0,6" FontWeight="Bold"/>
            <ComboBox x:Name="InputMicComboBox" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,20"
                      SelectionChanged="InputMicComboBox_SelectionChanged"/>
        </StackPanel>

        <!-- Info Discord (visibile solo se driver presente) -->
        <Border x:Name="DiscordInfoBorder" Background="#1E3A5F" CornerRadius="8" Padding="14,12" Margin="0,0,0,20" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="💬  Come usare su Discord" FontSize="12" FontWeight="Bold" Foreground="#5B9CF6" Margin="0,0,0,6"/>
                <TextBlock TextWrapping="Wrap" Foreground="#9AA0AE" FontSize="11">
                    <Run>Apri le Impostazioni di Discord → Voce e video → </Run>
                    <Run FontWeight="Bold" Foreground="#F1F2F6">Dispositivo di input</Run>
                    <Run> e seleziona </Run>
                    <Run FontWeight="Bold" Foreground="#5BE56B" x:Name="DiscordMicNameRun">ThePixelSoundboard Mic</Run>
                    <Run>. I tuoi amici sentiranno sia la tua voce che i suoni della board!</Run>
                </TextBlock>
            </StackPanel>
        </Border>

        <CheckBox x:Name="StartWithWindowsCheckBox"
                  Content="Avvia SoundBoard con Windows"
                  Margin="0,0,0,10"
                  Checked="StartWithWindowsCheckBox_Changed"
                  Unchecked="StartWithWindowsCheckBox_Changed"
                  Foreground="#F1F2F6"/>

        <CheckBox x:Name="NormalizeAudioCheckBox"
                  Content="Normalizza volume audio delle clip (evita suoni troppo alti o bassi)"
                  Margin="0,0,0,20"
                  Checked="NormalizeAudioCheckBox_Changed"
                  Unchecked="NormalizeAudioCheckBox_Changed"
                  Foreground="#F1F2F6"/>

        <TextBlock Text="Le impostazioni vengono salvate automaticamente."
                   Foreground="#F1F2F6" FontStyle="Italic" Margin="0,0,0,16"/>

        <!-- Versione -->
        <Border Background="#2A2E3A" CornerRadius="8" Padding="12,10" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="ThePixelSoundboard" FontSize="14" FontWeight="Bold" Foreground="#F1F2F6"/>
                <TextBlock Text="Versione 1.0.0 — per ThePixelBoys" Foreground="#9AA0AE" FontSize="11" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Button Content="Chiudi" Width="100" HorizontalAlignment="Right" Click="Close_Click"/>
    </StackPanel>
</Window>