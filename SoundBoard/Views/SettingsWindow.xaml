<Window x:Class="SoundBoard.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:SoundBoard.Services"
        Title="{Binding SettingsTitle, Source={x:Static services:L10n.Instance}}" Width="750" MinWidth="600" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Background="#1B1D23" Icon="/settings_icon.ico">
    <Window.Resources>
        <Style x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="#2A2E3A" BorderBrush="#3A3F4E" BorderThickness="1" CornerRadius="6">
                            <Grid HorizontalAlignment="Right" Width="30">
                                <Path x:Name="Arrow" Fill="#F1F2F6" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#353A49"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4C5265"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A2E3A"/>
                                <Setter TargetName="Arrow" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="180" CenterX="4" CenterY="2"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="ComboBoxTemplate" TargetType="ComboBox">
            <Grid>
                <ToggleButton Style="{StaticResource ComboBoxToggleButton}" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press"/>
                <ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" Margin="10,6,30,6" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                    <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                        <Border Name="DropDownBorder" Background="#232631" BorderBrush="#3A3F4E" BorderThickness="1" CornerRadius="6" Margin="0,2,0,0">
                            <ScrollViewer Margin="4" SnapsToDevicePixels="True" HorizontalScrollBarVisibility="Auto">
                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Popup>
            </Grid>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="Template" Value="{StaticResource ComboBoxTemplate}"/>
            <Setter Property="Foreground" Value="#F1F2F6"/>
            <Setter Property="Background" Value="#2A2E3A"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#F1F2F6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Name="Border" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True" CornerRadius="4">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#6C8CFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#6C8CFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainRootGrid" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="WindowTransform" Y="30"/>
        </Grid.RenderTransform>

        <Grid.Triggers>
            <EventTrigger RoutedEvent="Grid.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="WindowTransform"
                                         Storyboard.TargetProperty="Y"
                                         From="30" To="0" Duration="0:0:0.35"
                                         DecelerationRatio="0.9"/>
                        <DoubleAnimation Storyboard.TargetName="MainRootGrid"
                                         Storyboard.TargetProperty="Opacity"
                                         From="0" To="1" Duration="0:0:0.25"
                                         DecelerationRatio="0.9"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <StackPanel Margin="20">

        <!-- Lingua (Language Selection) -->
        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="{Binding LanguageLabel, Source={x:Static services:L10n.Instance}}" Foreground="#F1F2F6" Margin="0,0,0,6" FontWeight="Bold"/>
            <ComboBox x:Name="LanguageComboBox" SelectionChanged="LanguageComboBox_SelectionChanged">
                <ComboBoxItem x:Name="LanguageItItem" Content="Italiano (IT)" Tag="it"/>
                <ComboBoxItem x:Name="LanguageEnItem" Content="English (EN)" Tag="en"/>
                <ComboBoxItem x:Name="LanguageFrItem" Content="Français (FR)" Tag="fr"/>
                <ComboBoxItem x:Name="LanguageDeItem" Content="Deutsch (DE)" Tag="de"/>
            </ComboBox>
        </StackPanel>

        <!-- Output Amici (sempre visibile) -->
        <StackPanel x:Name="FriendsOutputPanel">
            <TextBlock Text="{Binding OutputDeviceFriends, Source={x:Static services:L10n.Instance}}" Foreground="#F1F2F6" Margin="0,0,0,6" FontWeight="Bold"/>
            <ComboBox x:Name="OutputFriendsComboBox" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,20"
                       SelectionChanged="OutputFriendsComboBox_SelectionChanged"/>
        </StackPanel>

        <!-- Output Cuffie (sempre visibile) -->
        <TextBlock Text="{Binding OutputDeviceMe, Source={x:Static services:L10n.Instance}}" Foreground="#F1F2F6" Margin="0,0,0,6" FontWeight="Bold"/>
        <ComboBox x:Name="OutputMeComboBox" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,20"
                  SelectionChanged="OutputMeComboBox_SelectionChanged"/>

        <CheckBox x:Name="StartWithWindowsCheckBox"
                  Content="{Binding StartWithWindows, Source={x:Static services:L10n.Instance}}"
                  Margin="0,0,0,10"
                  Checked="StartWithWindowsCheckBox_Changed"
                  Unchecked="StartWithWindowsCheckBox_Changed"
                  Foreground="#F1F2F6"/>

        <CheckBox x:Name="NormalizeAudioCheckBox"
                  Content="{Binding NormalizeAudioVolume, Source={x:Static services:L10n.Instance}}"
                  Margin="0,0,0,10"
                  Checked="NormalizeAudioCheckBox_Changed"
                  Unchecked="NormalizeAudioCheckBox_Changed"
                  Foreground="#F1F2F6"/>

        <!-- Slider per decibel di normalizzazione -->
        <StackPanel x:Name="NormalizationPanel" Margin="20,0,0,20">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="{Binding NormalizationTargetVolume, Source={x:Static services:L10n.Instance}}" Foreground="#9AA0AE" FontSize="11" FontWeight="SemiBold"/>
                <TextBlock x:Name="NormalizeDbValueText" Text="-1.0 dB" Foreground="#5BE56B" FontSize="11" FontWeight="Bold" Margin="8,0,0,0"/>
            </StackPanel>
            <Slider x:Name="NormalizeDbSlider" Minimum="-50" Maximum="0" TickFrequency="1" IsSnapToTickEnabled="True"
                    ValueChanged="NormalizeDbSlider_ValueChanged" />
        </StackPanel>

        <!-- Hotkey Globale Ferma Tutto -->
        <StackPanel Margin="0,0,0,16">
            <TextBlock Text="{Binding GlobalStopHotkey, Source={x:Static services:L10n.Instance}}" Foreground="#9AA0AE" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal">
                <Button Content="{Binding AssignHotkeyMenu, Source={x:Static services:L10n.Instance}}" Style="{StaticResource FlatButton}" Background="#2A2E3A" Foreground="#F1F2F6"
                        Padding="12,6" Click="AssignStopAllHotkey_Click"/>
                <TextBlock x:Name="StopAllHotkeyTextBlock" Text="Nessuna" Foreground="#5BE56B" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="Bold"/>
            </StackPanel>
        </StackPanel>

        <!-- Hotkey Globale Pausa Tutto -->
        <StackPanel Margin="0,0,0,16">
            <TextBlock Text="{Binding GlobalPauseHotkey, Source={x:Static services:L10n.Instance}}" Foreground="#9AA0AE" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal">
                <Button Content="{Binding AssignPauseMenu, Source={x:Static services:L10n.Instance}}" Style="{StaticResource FlatButton}" Background="#2A2E3A" Foreground="#F1F2F6"
                        Padding="12,6" Click="AssignPauseAllHotkey_Click"/>
                <TextBlock x:Name="PauseAllHotkeyTextBlock" Text="Nessuna" Foreground="#5BE56B" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="Bold"/>
            </StackPanel>
        </StackPanel>

        <TextBlock Text="{Binding SettingsAutoSaved, Source={x:Static services:L10n.Instance}}"
                   Foreground="#F1F2F6" FontStyle="Italic" Margin="0,0,0,10"/>

        <Button Content="{Binding OpenDataFolder, Source={x:Static services:L10n.Instance}}" Style="{StaticResource FlatButton}" Background="#2A2E3A" Foreground="#F1F2F6"
                HorizontalAlignment="Left" Padding="12,6" Margin="0,0,0,16" Click="OpenDataFolder_Click"/>

        <!-- Versione -->
        <Border Background="#2A2E3A" CornerRadius="8" Padding="12,10" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="ThePixelSoundboard" FontSize="14" FontWeight="Bold" Foreground="#F1F2F6"/>
                <TextBlock Text="{Binding VersionInfo, Source={x:Static services:L10n.Instance}}" Foreground="#9AA0AE" FontSize="11" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Grid>
            <Button Content="{Binding RepeatInitialSetup, Source={x:Static services:L10n.Instance}}" Style="{StaticResource FlatButton}" Background="#3498DB" Foreground="White"
                    HorizontalAlignment="Left" Padding="12,6" Click="ResetOnboarding_Click"/>
            <Button Content="{Binding Close, Source={x:Static services:L10n.Instance}}" Width="100" HorizontalAlignment="Right" Click="Close_Click"/>
        </Grid>
    </StackPanel>
    </Grid>
</Window>