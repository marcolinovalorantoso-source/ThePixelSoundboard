<Window x:Class="SoundBoard.Views.AudioTrimmerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tagliatore Audio (Trimmer)" Height="420" Width="600"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        ResizeMode="NoResize" Background="#14181F">

    <Window.Resources>
        <!-- Custom button style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#252A34"/>
            <Setter Property="Foreground" Value="#F1F2F6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3498DB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#1C212A"/>
                                <Setter Property="Foreground" Value="#4A5260"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainGrid" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="WindowTransform" Y="30"/>
        </Grid.RenderTransform>

        <Grid.Triggers>
            <EventTrigger RoutedEvent="Grid.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="WindowTransform"
                                         Storyboard.TargetProperty="Y"
                                         From="30" To="0" Duration="0:0:0.35"
                                         DecelerationRatio="0.9"/>
                        <DoubleAnimation Storyboard.TargetName="MainGrid"
                                         Storyboard.TargetProperty="Opacity"
                                         From="0" To="1" Duration="0:0:0.25"
                                         DecelerationRatio="0.9"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Waveform Visualizer -->
            <RowDefinition Height="Auto"/>   <!-- Sliders -->
            <RowDefinition Height="Auto"/>   <!-- Info & Timings -->
            <RowDefinition Height="Auto"/>   <!-- Actions (Buttons) -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1B202A" Padding="16,12" BorderBrush="#262D3D" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="✂️ TAGLIA SUONO" FontSize="11" FontWeight="Bold" Foreground="#3498DB"/>
                <TextBlock x:Name="SoundNameText" Text="Titolo del Suono" FontSize="15" FontWeight="SemiBold" Foreground="#F1F2F6" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Waveform Visualizer Area -->
        <Border Grid.Row="1" Background="#0F1218" Margin="16,16,16,10" CornerRadius="8" BorderBrush="#1C212D" BorderThickness="1" Height="100">
            <Grid>
                <!-- SoundCloud-Style Waveform -->
                <ItemsControl x:Name="WaveformItemsControl" VerticalAlignment="Bottom" Height="80" Margin="10,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="2.2" Margin="0.4,0" CornerRadius="1"
                                    Height="{Binding Height}"
                                    Background="{Binding Brush}"
                                    VerticalAlignment="Center"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
                <!-- Loading text when parsing -->
                <TextBlock x:Name="WaveformLoadingText" Text="Generazione traccia..." Foreground="#9AA0AE" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Controls (Sliders) -->
        <StackPanel Grid.Row="2" Margin="16,0,16,10">
            <!-- Start Point Slider -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Inizio:" Foreground="#9AA0AE" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" x:Name="StartSlider" Minimum="0" ValueChanged="StartSlider_ValueChanged" Height="22" 
                        ToolTip="Trascina per impostare il punto di inizio"/>
            </Grid>

            <!-- End Point Slider -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Fine:" Foreground="#9AA0AE" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" x:Name="EndSlider" Minimum="0" ValueChanged="EndSlider_ValueChanged" Height="22" 
                        ToolTip="Trascina per impostare il punto di fine"/>
            </Grid>
        </StackPanel>

        <!-- Info & Timings -->
        <Border Grid.Row="3" Background="#1B202A" Margin="16,0,16,16" Padding="12,8" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="INIZIO SELEZIONATO" FontSize="9" Foreground="#9AA0AE" FontWeight="Bold"/>
                    <TextBlock x:Name="StartTimeLabel" Text="0.00 s" FontSize="13" Foreground="#F1F2F6" FontWeight="SemiBold" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="FINE SELEZIONATA" FontSize="9" Foreground="#9AA0AE" FontWeight="Bold"/>
                    <TextBlock x:Name="EndTimeLabel" Text="0.00 s" FontSize="13" Foreground="#F1F2F6" FontWeight="SemiBold" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                    <TextBlock Text="DURATA FINALE" FontSize="9" Foreground="#3498DB" FontWeight="Bold"/>
                    <TextBlock x:Name="DurationLabel" Text="0.00 s" FontSize="13" Foreground="#2ECC71" FontWeight="Bold" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Actions -->
        <Border Grid.Row="4" Background="#11151B" Padding="16,12" BorderBrush="#1C212D" BorderThickness="0,1,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <!-- Play Selection -->
                    <Button x:Name="PlaySelectionButton" Content="▶ Ascolta Taglio" Click="PlaySelectionButton_Click" Background="#2ECC71" Foreground="White" Width="130" Margin="0,0,10,0"/>
                    <Button x:Name="StopSelectionButton" Content="🛑 Ferma" Click="StopSelectionButton_Click" Background="#E74C3C" Foreground="White" Width="90"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Salva" Click="SaveButton_Click" Background="#3498DB" Foreground="White" Width="100" Margin="0,0,10,0"/>
                    <Button Content="Annulla" Click="CancelButton_Click" Background="#2C3A47" Width="100"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
