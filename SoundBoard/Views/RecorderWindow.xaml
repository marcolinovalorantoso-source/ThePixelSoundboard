<Window x:Class="SoundBoard.Views.RecorderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:SoundBoard.Services"
        Title="{Binding RecorderTitle, Source={x:Static services:L10n.Instance}}" Width="480" Height="360"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1B1D23" Icon="/settings_icon.ico">
    <Window.Resources>
        <!-- Custom colors -->
        <SolidColorBrush x:Key="BgPanelBrush" Color="#232631"/>
        <SolidColorBrush x:Key="BgElevatedBrush" Color="#2A2E3A"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F1F2F6"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9AA0AE"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#D9534F"/> <!-- Red for recording -->
        <SolidColorBrush x:Key="SuccessBrush" Color="#2ECC71"/>

        <!-- ComboBox styling -->
        <Style x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="#2A2E3A" BorderBrush="#3A3F4E" BorderThickness="1" CornerRadius="6">
                            <Grid HorizontalAlignment="Right" Width="30">
                                <Path x:Name="Arrow" Fill="#F1F2F6" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#353A49"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4C5265"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A2E3A"/>
                                <Setter TargetName="Arrow" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="180" CenterX="4" CenterY="2"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="ComboBoxTemplate" TargetType="ComboBox">
            <Grid>
                <ToggleButton Style="{StaticResource ComboBoxToggleButton}" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press"/>
                <ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" Margin="10,6,30,6" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                    <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                        <Border Name="DropDownBorder" Background="#232631" BorderBrush="#3A3F4E" BorderThickness="1" CornerRadius="6" Margin="0,2,0,0">
                            <ScrollViewer Margin="4" SnapsToDevicePixels="True" HorizontalScrollBarVisibility="Auto">
                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Popup>
            </Grid>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="Template" Value="{StaticResource ComboBoxTemplate}"/>
            <Setter Property="Foreground" Value="#F1F2F6"/>
            <Setter Property="Background" Value="#2A2E3A"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#F1F2F6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Name="Border" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True" CornerRadius="4">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#D9534F"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#D9534F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title -->
            <RowDefinition Height="*"/>    <!-- Main controls -->
            <RowDefinition Height="Auto"/> <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{Binding RecorderHeader, Source={x:Static services:L10n.Instance}}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="{Binding RecorderDesc, Source={x:Static services:L10n.Instance}}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Main Panel -->
        <Border Grid.Row="1" Background="{StaticResource BgPanelBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <StackPanel VerticalAlignment="Center">
                <!-- Device selection -->
                <TextBlock Text="{Binding SelectMicrophone, Source={x:Static services:L10n.Instance}}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <ComboBox x:Name="DeviceComboBox" VerticalAlignment="Center" Margin="0,0,0,16"/>

                <!-- Status & Progress -->
                <TextBlock x:Name="StatusText" Text="{Binding ReadyToRecord, Source={x:Static services:L10n.Instance}}" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                
                <ProgressBar x:Name="RecordingProgress" Minimum="0" Maximum="5" Value="0" Height="8" Foreground="{StaticResource AccentBrush}" Background="#1B1D23" BorderThickness="0" Margin="0,0,0,16"/>

                <!-- Record Button -->
                <Button x:Name="RecordButton" Content="{Binding RecordMax5s, Source={x:Static services:L10n.Instance}}" Height="45" FontWeight="Bold" Background="#D9534F" Foreground="White" BorderThickness="0" Click="RecordButton_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <!-- Actions -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="{Binding PreviewBtn, Source={x:Static services:L10n.Instance}}" Width="120" Height="36" Click="PreviewButton_Click" Background="#2A2E3A" Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0" x:Name="PreviewButton" IsEnabled="False">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Grid.Column="2" Content="{Binding SaveAsButton, Source={x:Static services:L10n.Instance}}" Width="140" Height="36" Click="SaveButton_Click" Background="#2ECC71" Foreground="White" BorderThickness="0" x:Name="SaveButton" IsEnabled="False">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Grid>
</Window>
