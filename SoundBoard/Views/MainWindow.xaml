<Window x:Class="SoundBoard.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SoundBoard.ViewModels"
        xmlns:conv="clr-namespace:SoundBoard.Converters"
        Title="ThePixelSoundboard"
        Icon="/app_icon.ico"
        MinWidth="900" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        PreviewKeyDown="MainWindow_PreviewKeyDown">

    <Window.Resources>
        <conv:HexColorToBrushConverter x:Key="HexColorToBrush"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:MuteIconConverter x:Key="MuteIconConv"/>
        <conv:VolumePercentConverter x:Key="VolPct"/>
        <conv:VolumeDbConverter x:Key="VolDb"/>

        <!-- Template di un singolo pulsante suono nella griglia -->
        <DataTemplate x:Key="SoundTileTemplate" DataType="{x:Type vm:SoundButtonViewModel}">
            <Border Width="140" Height="100" Margin="6" CornerRadius="10"
                    Background="{Binding Color, Converter={StaticResource HexColorToBrush}}"
                    MouseLeftButtonUp="SoundTile_Click" Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="✏️ Modifica" Click="EditMenuItem_Click"/>
                        <MenuItem Header="⌨️ Assegna hotkey" Click="HotkeyMenuItem_Click"/>
                        <MenuItem Header="⭐ Preferito" Click="FavoriteMenuItem_Click"/>
                        <Separator/>
                        <MenuItem Header="🗑️ Elimina" Click="DeleteMenuItem_Click"/>
                    </ContextMenu>
                </Border.ContextMenu>
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding Icon}" FontSize="30"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                               MaxHeight="34" TextTrimming="CharacterEllipsis"/>
                    <Button Grid.Row="0" Content="{Binding FavoriteIcon}" VerticalAlignment="Top" HorizontalAlignment="Right"
                            Width="22" Height="22" Padding="0" FontSize="13" Background="Transparent" BorderThickness="0"
                            Click="FavoriteButton_Click" ToolTip="Preferito"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Template di una striscia del mixer (suono in riproduzione) -->
        <DataTemplate x:Key="MixerStripTemplate" DataType="{x:Type vm:SoundButtonViewModel}">
            <Border Width="180" Margin="6,4" Padding="10,8" CornerRadius="8" Background="{StaticResource BgElevatedBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>
                    
                    <!-- Controllo volume -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔊" FontSize="9" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding Volume, Mode=TwoWay}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Margin="6,0,0,0" FontSize="10" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    <Setter Property="Text" Value="{Binding Volume, Converter={StaticResource VolPct}}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.ShowDecibels, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                            <Setter Property="Text" Value="{Binding Volume, Converter={StaticResource VolDb}}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Barra di progresso / Seeking -->
                    <Grid Margin="0,0,0,6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Slider Grid.Row="0" Minimum="0" Maximum="{Binding TotalTimeSeconds, Mode=OneWay}" Value="{Binding CurrentTimeSeconds, Mode=OneWay}"
                                PreviewMouseLeftButtonDown="ProgressSlider_MouseDown"
                                PreviewMouseLeftButtonUp="ProgressSlider_MouseUp"
                                Height="18" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Text="{Binding TimeDisplay}" FontSize="9" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Grid>

                    <!-- Pulsanti di controllo -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Style="{StaticResource IconButton}"
                                Content="{Binding IsMuted, Converter={StaticResource MuteIconConv}}"
                                Command="{Binding DataContext.ToggleMuteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" Margin="0,0,6,0" ToolTip="Muta/Riattiva"/>
                        <Button Style="{StaticResource IconButton}" Content="⏹"
                                Command="{Binding DataContext.StopCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" ToolTip="Stop"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="{StaticResource BgDarkBrush}" AllowDrop="True"
          DragOver="RootGrid_DragOver" Drop="RootGrid_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Barra superiore -->
            <RowDefinition Height="*"/>       <!-- Corpo -->
            <RowDefinition Height="Auto"/>   <!-- Mixer -->
        </Grid.RowDefinitions>

        <!-- ===================== Barra superiore ===================== -->
        <Border Grid.Row="0" Background="{StaticResource BgPanelBrush}" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="ThePixelSoundboard" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" MouseDown="Logo_MouseDown"/>
                </StackPanel>

                <TextBox Grid.Column="1" Width="320" HorizontalAlignment="Left" VerticalAlignment="Center"
                          Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                          Tag="🔍 Cerca un suono...">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background" Value="{StaticResource BgElevatedBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <Button Grid.Column="2" Content="📁 Nuova cartella" Margin="8,0" Click="AddFolderButton_Click"/>
                <Button Grid.Column="3" Content="⬆️ Importa suoni" Margin="8,0" Click="ImportButton_Click"/>
                <Button Grid.Column="4" Content="🌐 MyInstants" Margin="8,0" Click="MyInstantsButton_Click"/>
                <Button Grid.Column="5" Content="🗣️ TTS (Voce)" Margin="8,0" Click="TtsButton_Click"/>
                <Button Grid.Column="6" Content="🎤 Registra" Margin="8,0" Click="RecorderButton_Click"/>
                <Button Grid.Column="7" Width="40" Height="40" Padding="8" Click="SettingsButton_Click" ToolTip="Impostazioni"
                        Background="Transparent" BorderThickness="0" OverridesDefaultStyle="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2A2E3A"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#353A49"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Image Source="/settings_gear.png" RenderOptions.BitmapScalingMode="HighQuality" Stretch="Uniform"/>
                </Button>
            </Grid>
        </Border>

        <!-- ===================== Corpo: sidebar + griglia ===================== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar cartelle -->
            <Border Grid.Column="0" Background="{StaticResource BgPanelBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <TextBlock Text="CARTELLE" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="8,10,8,6" FontWeight="Bold"/>
                    <Button Content="🗂️ Tutti i suoni" HorizontalContentAlignment="Left"
                            Background="Transparent" Click="SelectFolder_All"/>
                    <Button Content="⭐ Preferiti" HorizontalContentAlignment="Left"
                            Background="Transparent" Margin="0,2,0,0" Click="ToggleFavoritesFilter_Click"/>
                    <ListBox x:Name="FoldersListBox" ItemsSource="{Binding Folders}" SelectedItem="{Binding SelectedFolder}"
                             Margin="0,4,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ToolTip="Doppio click per rinominare" MouseLeftButtonDown="FolderItem_MouseLeftDown">
                                    <Grid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="✏️ Rinomina" Click="FolderRenameMenuItem_Click"/>
                                            <MenuItem Header="▶ Riproduci in sequenza" Click="FolderPlayMenuItem_Click"/>
                                            <Separator/>
                                            <MenuItem Header="🗑️ Elimina" Click="FolderDeleteMenuItem_Click"/>
                                        </ContextMenu>
                                    </Grid.ContextMenu>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="▶" Width="20" Height="20" FontSize="10"
                                            Background="Transparent" Click="PlayFolderButton_Click"
                                            ToolTip="Riproduci tutti in sequenza"/>
                                    <Button Grid.Column="2" Content="✕" Width="20" Height="20" FontSize="10"
                                            Background="Transparent" Click="DeleteFolderButton_Click"
                                            ToolTip="Elimina cartella"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Riproduzione sequenziale in corso -->
                    <Button Content="⏹ Ferma sequenza" Margin="0,8,0,0" Background="{StaticResource DangerBrush}"
                            Command="{Binding StopSequenceCommand}"
                            Visibility="{Binding IsSequencePlaying, Converter={StaticResource BoolToVis}}"/>

                    <!-- Cronologia -->
                    <TextBlock Text="CRONOLOGIA" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="8,18,8,6" FontWeight="Bold"/>
                    <ItemsControl ItemsSource="{Binding History}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:SoundButtonViewModel}">
                                <Border Background="{StaticResource BgElevatedBrush}" CornerRadius="6"
                                        Padding="6,4" Margin="0,0,0,4" Cursor="Hand"
                                        MouseLeftButtonUp="HistoryTile_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}" FontSize="13" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding Name}" FontSize="11" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Griglia pulsanti suono -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="10">
                <ItemsControl ItemsSource="{Binding FilteredButtons}" ItemTemplate="{StaticResource SoundTileTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ===================== Mixer inferiore ===================== -->
        <Border Grid.Row="2" Background="{StaticResource BgPanelBrush}" Padding="10" MinHeight="120">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding PlayingSounds}" ItemTemplate="{StaticResource MixerStripTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Master volume -->
                <Border Grid.Column="1" Background="{StaticResource BgElevatedBrush}" CornerRadius="8"
                        Padding="14,8" Margin="10,4" Width="200">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="🔊 MASTER" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Margin="8,0,0,0" FontSize="11" FontWeight="Bold" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                        <Setter Property="Text" Value="{Binding MasterVolume, Converter={StaticResource VolPct}}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowDecibels}" Value="True">
                                                <Setter Property="Text" Value="{Binding MasterVolume, Converter={StaticResource VolDb}}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <Slider Minimum="0" Maximum="1" Value="{Binding MasterVolume, Mode=TwoWay}" Margin="0,0,0,8"/>
                        <Button FontSize="11" Padding="6,4" Click="ToggleAdvancedAudio_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource FlatButton}">
                                    <Setter Property="Content" Value="🎛 Audio avanzato (dB)"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowDecibels}" Value="True">
                                            <Setter Property="Content" Value="🎛 Audio semplice (%)"/>
                                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
