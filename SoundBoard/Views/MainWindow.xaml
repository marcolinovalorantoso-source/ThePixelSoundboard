<Window x:Class="SoundBoard.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SoundBoard.ViewModels"
        xmlns:conv="clr-namespace:SoundBoard.Converters"
        Title="ThePixelSoundboard"
        Icon="/app_icon.ico"
        MinWidth="900" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        PreviewKeyDown="MainWindow_PreviewKeyDown">

    <Window.Resources>
        <conv:HexColorToBrushConverter x:Key="HexColorToBrush"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:MuteIconConverter x:Key="MuteIconConv"/>
        <conv:VolumePercentConverter x:Key="VolPct"/>
        <conv:VolumeDbConverter x:Key="VolDb"/>

        <!-- Template di un singolo pulsante suono nella griglia -->
        <DataTemplate x:Key="SoundTileTemplate" DataType="{x:Type vm:SoundButtonViewModel}">
            <Border Width="140" Height="100" Margin="6" CornerRadius="10"
                    Background="{Binding Color, Converter={StaticResource HexColorToBrush}}"
                    MouseLeftButtonUp="SoundTile_Click" Cursor="Hand" RenderTransformOrigin="0.5,0.5"
                    AllowDrop="True" Drop="SoundTile_Drop" 
                    PreviewMouseLeftButtonDown="SoundTile_PreviewMouseLeftButtonDown" 
                    PreviewMouseMove="SoundTile_PreviewMouseMove">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Border.MouseDown">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0.94" Duration="0:0:0.08"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0.94" Duration="0:0:0.08"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="Border.MouseUp">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.08"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.08"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="Border.MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.08"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.08"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="✏️ Modifica" Click="EditMenuItem_Click"/>
                        <MenuItem Header="✂️ Taglia Audio" Click="TrimMenuItem_Click"/>
                        <MenuItem Header="⌨️ Assegna hotkey" Click="HotkeyMenuItem_Click"/>
                        <MenuItem Header="⭐ Preferito" Click="FavoriteMenuItem_Click"/>
                        <Separator/>
                        <MenuItem Header="🗑️ Elimina" Click="DeleteMenuItem_Click"/>
                    </ContextMenu>
                </Border.ContextMenu>
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding Icon}" FontSize="30"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                               MaxHeight="34" TextTrimming="CharacterEllipsis"/>
                    <Button Grid.Row="0" Content="{Binding FavoriteIcon}" VerticalAlignment="Top" HorizontalAlignment="Right"
                            Width="22" Height="22" Padding="0" FontSize="13" Background="Transparent" BorderThickness="0"
                            Click="FavoriteButton_Click" ToolTip="Preferito"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Template di una striscia del mixer (suono in riproduzione) -->
        <DataTemplate x:Key="MixerStripTemplate" DataType="{x:Type vm:SoundButtonViewModel}">
            <Border Width="180" Margin="6,4" Padding="10,8" CornerRadius="8" Background="{StaticResource BgElevatedBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>
                    
                    <!-- Controllo volume -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔊" FontSize="9" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding Volume, Mode=TwoWay}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Margin="6,0,0,0" FontSize="10" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    <Setter Property="Text" Value="{Binding Volume, Converter={StaticResource VolPct}}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.ShowDecibels, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                            <Setter Property="Text" Value="{Binding Volume, Converter={StaticResource VolDb}}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Barra di progresso / Seeking -->
                    <Grid Margin="0,0,0,6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Slider Grid.Row="0" Minimum="0" Maximum="{Binding TotalTimeSeconds, Mode=OneWay}" Value="{Binding CurrentTimeSeconds, Mode=OneWay}"
                                PreviewMouseLeftButtonDown="ProgressSlider_MouseDown"
                                PreviewMouseLeftButtonUp="ProgressSlider_MouseUp"
                                Height="18" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Text="{Binding TimeDisplay}" FontSize="9" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Grid>

                    <!-- Pulsanti di controllo -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Style="{StaticResource IconButton}"
                                Content="{Binding IsMuted, Converter={StaticResource MuteIconConv}}"
                                Command="{Binding DataContext.ToggleMuteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" Margin="0,0,6,0" ToolTip="Muta/Riattiva"/>
                        
                        <!-- Pulsante Play/Pausa -->
                        <Button Command="{Binding DataContext.TogglePauseCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" Margin="0,0,6,0" ToolTip="Pausa/Riprendi">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                    <Setter Property="Content" Value="⏸"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                            <Setter Property="Content" Value="▶"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Style="{StaticResource IconButton}" Content="⏹"
                                Command="{Binding DataContext.StopCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" ToolTip="Stop"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
        <!-- Style for Drawer menu items -->
        <Style x:Key="DrawerMenuItemStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#F1F2F6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1C2230"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#252F42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="{StaticResource BgDarkBrush}" AllowDrop="True"
          DragOver="RootGrid_DragOver" Drop="RootGrid_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Barra superiore -->
            <RowDefinition Height="*"/>       <!-- Corpo -->
            <RowDefinition Height="Auto"/>   <!-- Mixer -->
        </Grid.RowDefinitions>

        <!-- ===================== Barra superiore ===================== -->
        <Border Grid.Row="0" Background="{StaticResource BgPanelBrush}" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="186"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Click="HamburgerButton_Click" Background="{StaticResource AccentBrush}" Foreground="#FFFFFF" 
                        BorderThickness="0" Cursor="Hand" ToolTip="Apri Menu Strumenti" Height="36" HorizontalAlignment="Left"
                        OverridesDefaultStyle="True" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="18" Padding="14,6">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="✨" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Menu Strumenti" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <TextBox Grid.Column="1" Width="320" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0,0,0"
                          Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                          Tag="🔍 Cerca qui...">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background" Value="{StaticResource BgElevatedBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <Button Grid.Column="2" Content="📁 Nuova cartella" Margin="8,0" Click="AddFolderButton_Click"/>
                <Button Grid.Column="3" Content="⬆️ Importa suoni" Margin="8,0" Click="ImportButton_Click"/>
                
                <Button Grid.Column="4" Width="40" Height="40" Padding="8" Click="SettingsButton_Click" ToolTip="Impostazioni"
                        Background="Transparent" BorderThickness="0" OverridesDefaultStyle="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                    RenderTransformOrigin="0.5,0.5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#2A2E3A"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#353A49"/>
                                    <Setter TargetName="border" Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.88" ScaleY="0.88"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Image Source="/settings_gear.png" RenderOptions.BitmapScalingMode="HighQuality" Stretch="Uniform"/>
                </Button>
            </Grid>
        </Border>

        <!-- ===================== Corpo: sidebar + griglia ===================== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar cartelle -->
            <Border Grid.Column="0" Background="{StaticResource BgPanelBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <TextBlock Text="CARTELLE" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="8,10,8,6" FontWeight="Bold"/>
                    <Button Content="🗂️ Tutti i suoni" HorizontalContentAlignment="Left"
                            Background="Transparent" Click="SelectFolder_All"/>
                    <Button Content="⭐ Preferiti" HorizontalContentAlignment="Left"
                            Background="Transparent" Margin="0,2,0,0" Click="ToggleFavoritesFilter_Click"/>
                    <ListBox x:Name="FoldersListBox" ItemsSource="{Binding Folders}" SelectedItem="{Binding SelectedFolder}"
                             Margin="0,4,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ToolTip="Doppio click per rinominare" MouseLeftButtonDown="FolderItem_MouseLeftDown">
                                    <Grid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="✏️ Rinomina" Click="FolderRenameMenuItem_Click"/>
                                            <MenuItem Header="▶ Riproduci in sequenza" Click="FolderPlayMenuItem_Click"/>
                                            <Separator/>
                                            <MenuItem Header="🗑️ Elimina" Click="FolderDeleteMenuItem_Click"/>
                                        </ContextMenu>
                                    </Grid.ContextMenu>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="▶" Width="20" Height="20" FontSize="10"
                                            Background="Transparent" Click="PlayFolderButton_Click"
                                            ToolTip="Riproduci tutti in sequenza"/>
                                    <Button Grid.Column="2" Content="✕" Width="20" Height="20" FontSize="10"
                                            Background="Transparent" Click="DeleteFolderButton_Click"
                                            ToolTip="Elimina cartella"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Riproduzione sequenziale in corso -->
                    <Button Content="⏹ Ferma sequenza" Margin="0,8,0,0" Background="{StaticResource DangerBrush}"
                            Command="{Binding StopSequenceCommand}"
                            Visibility="{Binding IsSequencePlaying, Converter={StaticResource BoolToVis}}"/>

                    <!-- Cronologia -->
                    <!-- Cronologia Header -->
                    <Grid Margin="8,20,8,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🕒" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="CRONOLOGIA" FontSize="10.5" FontWeight="Bold" 
                                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <!-- Bottone Cancella (mostrato solo se la cronologia ha elementi) -->
                        <Button Grid.Column="1" Click="ClearHistory_Click" Background="Transparent" Foreground="#5F677A"
                                BorderThickness="0" Cursor="Hand" Padding="4,2" FontSize="9" FontWeight="SemiBold"
                                ToolTip="Pulisci cronologia" VerticalAlignment="Center" OverridesDefaultStyle="True">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding History.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock Text="Cancella" x:Name="btnTxt"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="btnTxt" Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Stato vuoto cronologia (mostrato se History è vuota) -->
                    <Border Margin="8,4,8,8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding History.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal" Opacity="0.45">
                            <TextBlock Text="💤" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Nessun suono recente" FontSize="10.5" FontStyle="Italic" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Lista elementi della cronologia -->
                    <ItemsControl ItemsSource="{Binding History}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:SoundButtonViewModel}">
                                <Border x:Name="itemBorder" Background="#1D212A" CornerRadius="6"
                                        Padding="8,6" Margin="0,0,0,4" Cursor="Hand"
                                        MouseLeftButtonUp="HistoryTile_Click" RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    </Border.RenderTransform>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseCaptured" Value="True">
                                                    <Setter Property="RenderTransform">
                                                        <Setter.Value>
                                                            <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="11" TextTrimming="CharacterEllipsis"
                                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                        
                                        <!-- Bottone elimina singolo elemento -->
                                        <Button Grid.Column="2" Click="RemoveFromHistory_Click" Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" ToolTip="Rimuovi" OverridesDefaultStyle="True" VerticalAlignment="Center" Margin="4,0,0,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <TextBlock Text="✕" FontSize="9.5" x:Name="delTxt" Foreground="#4A5260"/>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="delTxt" Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <Trigger SourceName="itemBorder" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="itemBorder" Property="Background" Value="#252A36"/>
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Griglia pulsanti suono -->
            <Grid Grid.Column="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <ItemsControl ItemsSource="{Binding FilteredButtons}" ItemTemplate="{StaticResource SoundTileTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Empty State (mostrato solo se non ci sono suoni nella vista corrente) -->
                <Border x:Name="EmptyStateView" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="380" Margin="20">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FilteredButtons.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <!-- Icona olografica/neon -->
                        <Border Width="80" Height="80" CornerRadius="40" Background="#1C2230" BorderBrush="#2C3446" BorderThickness="1" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <TextBlock Text="🎵" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <!-- Titolo -->
                        <TextBlock Text="Non c'è ancora nessun suono" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <!-- Descrizione -->
                        <TextBlock Text="Questa cartella è vuota. Trascina i tuoi file audio (.mp3, .wav) direttamente qui per aggiungerli, oppure usa il menu strumenti in alto per cercarli e scaricarli da internet!" 
                                   TextWrapping="Wrap" TextAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" LineHeight="18" Margin="0,0,0,24"/>
                        <!-- Pulsante di importazione rapida -->
                        <Button Content="➕  Aggiungi il tuo primo suono" Click="ImportButton_Click" HorizontalAlignment="Center" Padding="18,10" Style="{StaticResource FlatButton}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ===================== Mixer inferiore ===================== -->
        <Border Grid.Row="2" Background="{StaticResource BgPanelBrush}" Padding="10" MinHeight="120">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding PlayingSounds}" ItemTemplate="{StaticResource MixerStripTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Master volume -->
                <Border Grid.Column="1" Background="{StaticResource BgElevatedBrush}" CornerRadius="8"
                        Padding="14,8" Margin="10,4" Width="200">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="🔊 MASTER" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Margin="8,0,0,0" FontSize="11" FontWeight="Bold" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                        <Setter Property="Text" Value="{Binding MasterVolume, Converter={StaticResource VolPct}}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowDecibels}" Value="True">
                                                <Setter Property="Text" Value="{Binding MasterVolume, Converter={StaticResource VolDb}}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <Slider Minimum="0" Maximum="1" Value="{Binding MasterVolume, Mode=TwoWay}" Margin="0,0,0,8"/>
                        <Button FontSize="11" Padding="6,4" Click="ToggleAdvancedAudio_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource FlatButton}">
                                    <Setter Property="Content" Value="🎛 Audio avanzato (dB)"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowDecibels}" Value="True">
                                            <Setter Property="Content" Value="🎛 Audio semplice (%)"/>
                                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Backdrop (semi-trasparente) -->
        <Border x:Name="DrawerBackdrop" Grid.Row="0" Grid.RowSpan="3" Background="#80000000" Visibility="Collapsed" Opacity="0" MouseDown="DrawerBackdrop_MouseDown"/>

        <!-- Pannello Scorrevole (Drawer) -->
        <Border x:Name="DrawerPanel" Grid.Row="0" Grid.RowSpan="3" Width="240" HorizontalAlignment="Left" Background="#141822" BorderBrush="#1C2230" BorderThickness="0,0,1,0" Visibility="Collapsed">
            <Border.RenderTransform>
                <TranslateTransform x:Name="DrawerTransform" X="-240"/>
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Header con titolo e bottone chiudi -->
                    <RowDefinition Height="*"/>      <!-- Lista comandi -->
                    <RowDefinition Height="Auto"/>   <!-- Footer (versione o info) -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" BorderBrush="#1C2230" BorderThickness="0,0,0,1" Padding="16,14">
                    <Grid>
                        <TextBlock Text="MENU STRUMENTI" FontSize="11" FontWeight="Bold" Foreground="#3498DB" VerticalAlignment="Center"/>
                        <Button Content="✕" Width="24" Height="24" FontSize="10" Background="Transparent" Foreground="#9AA0AE" HorizontalAlignment="Right" Click="CloseDrawerButton_Click" ToolTip="Chiudi"/>
                    </Grid>
                </Border>

                <!-- Comandi / Strumenti -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,10">
                    <StackPanel Margin="8,0">
                        <Button Style="{StaticResource DrawerMenuItemStyle}" Click="MyInstantsButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🌐" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="Cerca Online" FontWeight="SemiBold" Foreground="#F1F2F6" FontSize="13"/>
                                    <TextBlock Text="Scarica da MyInstants" Foreground="#9AA0AE" FontSize="10" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource DrawerMenuItemStyle}" Margin="0,4,0,0" Click="TtsButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗣️" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="TTS (Voce)" FontWeight="SemiBold" Foreground="#F1F2F6" FontSize="13"/>
                                    <TextBlock Text="Sintesi vocale da testo" Foreground="#9AA0AE" FontSize="10" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource DrawerMenuItemStyle}" Margin="0,4,0,0" Click="RecorderButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎤" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="Registra Audio" FontWeight="SemiBold" Foreground="#F1F2F6" FontSize="13"/>
                                    <TextBlock Text="Registra da microfono" Foreground="#9AA0AE" FontSize="10" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource DrawerMenuItemStyle}" Margin="0,4,0,0" Click="OpenSoundsFolder_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📁" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="Apri Cartella" FontWeight="SemiBold" Foreground="#F1F2F6" FontSize="13"/>
                                    <TextBlock Text="Gestisci i file audio dell'app" Foreground="#9AA0AE" FontSize="10" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource DrawerMenuItemStyle}" Margin="0,4,0,0" Click="DrawerItem_Settings_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙️" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="Impostazioni" FontWeight="SemiBold" Foreground="#F1F2F6" FontSize="13"/>
                                    <TextBlock Text="Configura preferenze e audio" Foreground="#9AA0AE" FontSize="10" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource DrawerMenuItemStyle}" Margin="0,4,0,0" Click="ClearAllSoundsButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗑️" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="Svuota Soundboard" FontWeight="SemiBold" Foreground="#FF6B6B" FontSize="13"/>
                                    <TextBlock Text="Rimuovi tutti i suoni caricati" Foreground="#9AA0AE" FontSize="10" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>

                        <!-- Scheda Statistiche -->
                        <Border Background="#161B26" BorderBrush="#252F42" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,24,0,0">
                            <StackPanel>
                                <TextBlock Text="📊 STATISTICHE" FontSize="9" FontWeight="Bold" Foreground="#3498DB" Margin="0,0,0,8"/>
                                <Grid Margin="0,2">
                                    <TextBlock Text="Suoni salvati:" FontSize="10.5" Foreground="#9AA0AE"/>
                                    <TextBlock Text="{Binding AllButtons.Count}" FontSize="10.5" FontWeight="Bold" Foreground="#F1F2F6" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,2">
                                    <TextBlock Text="Cartelle create:" FontSize="10.5" Foreground="#9AA0AE"/>
                                    <TextBlock Text="{Binding Folders.Count}" FontSize="10.5" FontWeight="Bold" Foreground="#F1F2F6" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer -->
                <TextBlock Grid.Row="2" Text="ThePixelSoundboard v2.5" FontSize="10" Foreground="#4A5260" HorizontalAlignment="Center" Margin="0,16"/>
            </Grid>
        </Border>
    </Grid>
</Window>
