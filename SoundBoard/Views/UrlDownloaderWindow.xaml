<Window x:Class="SoundBoard.Views.UrlDownloaderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:SoundBoard.Services"
        Title="{Binding UrlTitle, Source={x:Static services:L10n.Instance}}" Width="500" Height="360"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1B1D23" Icon="/settings_icon.ico">
    <Window.Resources>
        <!-- Custom colors -->
        <SolidColorBrush x:Key="BgPanelBrush" Color="#232631"/>
        <SolidColorBrush x:Key="BgElevatedBrush" Color="#2A2E3A"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F1F2F6"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9AA0AE"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#3498DB"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#2ECC71"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Input URL -->
            <RowDefinition Height="Auto"/> <!-- Trim Options -->
            <RowDefinition Height="*"/>    <!-- Status & Progress -->
            <RowDefinition Height="Auto"/> <!-- Actions -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{Binding UrlHeader, Source={x:Static services:L10n.Instance}}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="{Binding UrlDesc, Source={x:Static services:L10n.Instance}}" 
                       TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,0" LineHeight="15"/>
        </StackPanel>

        <!-- Input URL -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="UrlTextBox" Height="36" Padding="10,0" VerticalContentAlignment="Center"
                     Background="{StaticResource BgPanelBrush}" BorderBrush="#3A3F4E" BorderThickness="1" Foreground="{StaticResource TextPrimaryBrush}"
                     GotFocus="UrlTextBox_GotFocus" LostFocus="UrlTextBox_LostFocus"/>
        </Grid>

        <!-- Trim Options -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="{Binding StartCutOptional, Source={x:Static services:L10n.Instance}}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                <TextBox x:Name="StartTextBox" Height="30" Padding="8,0" VerticalContentAlignment="Center"
                         Background="{StaticResource BgPanelBrush}" BorderBrush="#3A3F4E" BorderThickness="1" Foreground="{StaticResource TextPrimaryBrush}"
                         GotFocus="StartTextBox_GotFocus" LostFocus="StartTextBox_LostFocus"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                <TextBlock Text="{Binding EndCutOptional, Source={x:Static services:L10n.Instance}}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                <TextBox x:Name="EndTextBox" Height="30" Padding="8,0" VerticalContentAlignment="Center"
                         Background="{StaticResource BgPanelBrush}" BorderBrush="#3A3F4E" BorderThickness="1" Foreground="{StaticResource TextPrimaryBrush}"
                         GotFocus="EndTextBox_GotFocus" LostFocus="EndTextBox_LostFocus"/>
            </StackPanel>
        </Grid>

        <!-- Status & Progress -->
        <Grid Grid.Row="3">
            <StackPanel x:Name="ProgressPanel" Visibility="Collapsed">
                <TextBlock x:Name="StatusTextBlock" Text="{Binding Downloading, Source={x:Static services:L10n.Instance}}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8"/>
                <ProgressBar x:Name="DownloadProgressBar" Height="6" IsIndeterminate="True" Background="{StaticResource BgPanelBrush}" Foreground="{StaticResource AccentBrush}"/>
            </StackPanel>
            <TextBlock x:Name="IdleTextBlock" Text="{Binding ReadyToDownload, Source={x:Static services:L10n.Instance}}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Top"/>
        </Grid>

        <!-- Actions -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="CancelBtn" Content="{Binding Cancel, Source={x:Static services:L10n.Instance}}" Width="90" Height="34" Margin="0,0,10,0" 
                    Style="{StaticResource FlatButton}" Background="{StaticResource BgPanelBrush}" Foreground="{StaticResource TextPrimaryBrush}" Click="CancelButton_Click"/>
            <Button x:Name="DownloadBtn" Content="{Binding DownloadMp3, Source={x:Static services:L10n.Instance}}" Width="130" Height="34" 
                    Style="{StaticResource FlatButton}" Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="Bold" Click="DownloadButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
